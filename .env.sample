# eJARN 로그인 정보 (필수)
EJARN_LOGIN_EMAIL=your@email.com
EJARN_LOGIN_PASSWORD=your_password

# OpenAI API 키 (선택)
OPENAI_API_KEY=

# LLM 기능 활성화 여부 (선택)
EJARN_USE_LLM_SUMMARY=false
EJARN_USE_LLM_CLASSIFY=false

# 수집 설정 (선택)
EJARN_MAX_ARTICLES=10
# EJARN_LIST_URL=https://www.ejarn.com/category/eJarn_news_index
# EJARN_VERIFY_SSL=true
# EJARN_REQUEST_TIMEOUT=15
# EJARN_USE_PLAYWRIGHT=true

# 배치(전 섹션) 수집 옵션 (선택)
EJARN_SINCE_DATE=2026-03-15
EJARN_RESULT_SUBDIR=2604
EJARN_MAX_LIST_ARTICLES=400
EJARN_MAX_TOPICS=200
EJARN_BATCH_SECTION_MAX=10

